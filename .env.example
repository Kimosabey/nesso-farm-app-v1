# =========================================================
# Nesso · Root .env example  ·  copy to .env (gitignored)
# =========================================================
# Per-app env files live in apps/*/.env.example
# Anything here is consumed by docker-compose / scripts.
# =========================================================

# Mongo (Docker local)
MONGO_USER=nesso
MONGO_PASS=nesso

# Redis (Docker local)
REDIS_PASS=

# Minio (S3 stub, Docker local)
MINIO_ROOT_USER=nesso
MINIO_ROOT_PASSWORD=nessoadmin
MINIO_BUCKET=nesso-dev

# Where the API listens (4000 to avoid the common 3000 conflict with Grafana/etc.)
API_PORT=4000

# Where the web dashboard listens
WEB_PORT=3001

# Where the public QR portal listens
PORTAL_PORT=3002
