# EAS Build uses pnpm to install our deps, but the workspace root's
# `node-linker=isolated` setting (which keeps local dev clean) makes
# EAS's pre-built native modules fail to locate their peers during
# Gradle / CocoaPods linking. Override to hoisted for the EAS sandbox
# only — local pnpm installs from the repo root still use isolated
# because that .npmrc takes precedence in the workspace tree.
node-linker=hoisted
