# ==================================================
# Nesso API · environment template  ·  copy to .env
# ==================================================

# --- Server ---
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# --- Database ---
MONGODB_URI=mongodb://nesso:nesso@localhost:27017/nesso?authSource=admin

# --- Cache / queue / OTP store ---
REDIS_URL=redis://localhost:6379

# --- JWT (RS256) — generate keys in Phase 1 ---
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- S3 / Minio (local stub) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=nesso-dev
S3_ACCESS_KEY=nesso
S3_SECRET_KEY=nessoadmin
S3_FORCE_PATH_STYLE=true

# --- Firebase Admin (Phase 1) ---
FIREBASE_SERVICE_ACCOUNT_JSON=

# --- Bootstrap admin (Phase 1 seed) ---
BOOTSTRAP_ADMIN_PHONE=9066666481
BOOTSTRAP_ADMIN_PASSWORD=change-me-on-first-login

# --- Observability ---
SENTRY_DSN=
LOG_LEVEL=info

# --- CORS allowlist ---
CORS_ORIGINS=http://localhost:3001,http://localhost:3002
