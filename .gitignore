# Mobile (iOS)
ios/build
ios/Pods
ios/DerivedData
ios/*.xcworkspace/xcuserdata
ios/*.xcodeproj/xcuserdata

# Native Expo prebuild outputs (regenerable)
apps/mobile/android
apps/mobile/ios

# Secrets / keys
*.pem
*.key
keys/
google-services.json
GoogleService-Info.plist
# Firebase service account JSONs — any name pattern, anywhere in the tree
*firebase-adminsdk*.json
*-firebase-adminsdk-*.json
firebase-service-account*.json
*service-account*.json

# Test artifacts
coverage
*.lcov
.nyc_output

# Misc
.cache
.parcel-cache
.eslintcache
*.tsbuildinfo

# Stale TS emission inside src/ (NestJS sometimes mis-emits when tsconfig changes)
apps/api/src/**/*.d.ts
apps/api/src/**/*.d.ts.map
apps/api/src/**/*.js
apps/api/src/**/*.js.map
